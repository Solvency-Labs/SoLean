{
  "contract": {
    "name": "Counter",
    "pragma": "0.8.20"
  },
  "function": {
    "body": {
      "seq": [
        {
          "require": {
            "gt": [
              {
                "param": "amount"
              },
              {
                "const": 0
              }
            ]
          }
        },
        {
          "assign": {
            "expr": {
              "add": [
                {
                  "slot": 0
                },
                {
                  "param": "amount"
                }
              ]
            },
            "slot": 0
          }
        },
        {
          "assert": {
            "ge": [
              {
                "slot": 0
              },
              {
                "param": "amount"
              }
            ]
          }
        }
      ]
    },
    "name": "inc",
    "param": {
      "name": "amount",
      "type": "uint256"
    }
  },
  "kind": "sourceFunction",
  "lean": "SoLean.Examples.CounterCompiler.counterFunction",
  "storage": {
    "x": {
      "slot": 0,
      "type": "uint256",
      "visibility": "public"
    }
  }
}
